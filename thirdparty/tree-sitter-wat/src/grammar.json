{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "wat",
  "word": "keyword",
  "rules": {
    "root": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_child"
      }
    },
    "sexpr": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_child"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "_child": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "sexpr"
        },
        {
          "type": "SYMBOL",
          "name": "_leaf_token"
        }
      ]
    },
    "_leaf_token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "keyword"
          }
        },
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "u"
          }
        },
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "s"
          }
        },
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "f"
          }
        },
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "string"
          }
        },
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "id"
          }
        },
        {
          "type": "PREC",
          "value": 0,
          "content": {
            "type": "SYMBOL",
            "name": "reserved"
          }
        }
      ]
    },
    "id": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "$"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "PATTERN",
                  "value": "[0-9A-Za-z!#$%&'*+\\-.\\/:<=>?@\\\\^_`|~]"
                }
              },
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "\""
                  },
                  {
                    "type": "REPEAT",
                    "content": {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "PATTERN",
                          "value": "[^\"\\\\]+"
                        },
                        {
                          "type": "PATTERN",
                          "value": "\\\\[tnr\"'\\\\]"
                        },
                        {
                          "type": "PATTERN",
                          "value": "\\\\[0-9A-Fa-f]{2}"
                        },
                        {
                          "type": "PATTERN",
                          "value": "\\\\u\\{[0-9A-Fa-f]+\\}"
                        }
                      ]
                    }
                  },
                  {
                    "type": "STRING",
                    "value": "\""
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"\\\\]+"
                },
                {
                  "type": "PATTERN",
                  "value": "\\\\[tnr\"'\\\\]"
                },
                {
                  "type": "PATTERN",
                  "value": "\\\\[0-9A-Fa-f]{2}"
                },
                {
                  "type": "PATTERN",
                  "value": "\\\\u\\{[0-9A-Fa-f]+\\}"
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "u": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "(?:0x[0-9A-Fa-f]+(?:_[0-9A-Fa-f]+)*|[0-9]+(?:_[0-9]+)*)"
      }
    },
    "s": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[+-](?:0x[0-9A-Fa-f]+(?:_[0-9A-Fa-f]+)*|[0-9]+(?:_[0-9]+)*)"
      }
    },
    "f": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[+-]?(?:0x[0-9A-Fa-f]+(?:_[0-9A-Fa-f]+)*(?:\\.(?:[0-9A-Fa-f]+(?:_[0-9A-Fa-f]+)*)?)?(?:[pP][+-]?[0-9]+(?:_[0-9]+)*)?|[0-9]+(?:_[0-9]+)*(?:\\.(?:[0-9]+(?:_[0-9]+)*)?)?(?:[eE][+-]?[0-9]+(?:_[0-9]+)*)?|inf|nan(?::0x[0-9A-Fa-f]+(?:_[0-9A-Fa-f]+)*)?)"
      }
    },
    "keyword": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[a-z]"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "PATTERN",
              "value": "[0-9A-Za-z!#$%&'*+\\-.\\/:<=>?@\\\\^_`|~]"
            }
          }
        ]
      }
    },
    "reserved": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\s();]+"
      }
    },
    "_line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": ";;"
            },
            {
              "type": "PATTERN",
              "value": "[^\\n\\r]*"
            }
          ]
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "_line_comment"
    },
    {
      "type": "SYMBOL",
      "name": "_block_comment"
    },
    {
      "type": "SYMBOL",
      "name": "annotation"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_block_comment"
    },
    {
      "type": "SYMBOL",
      "name": "annotation"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}